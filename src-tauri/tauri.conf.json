{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "花笺便签",
  "version": "1.0.0",
  "identifier": "com.desktopnote.floral",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "花笺便签",
        "width": 1120,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
